{
  "name": "class-schedule-desktop",
  "version": "1.1.0",
  "description": "课表助手 - Windows桌面版",
  "main": "src-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5199 && node scripts/electron-launcher.js .\"",
    "build": "vite build && electron-builder --win",
    "start": "node scripts/electron-launcher.js .",
    "vite:build": "vite build"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sql.js": "^1.12.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "concurrently": "^9.1.0",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.8.0",
    "vite": "^6.2.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.neofyq.classschedule.desktop",
    "productName": "课表助手",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": null,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "language": "2052"
    },
    "files": [
      "dist/**/*",
      "src-electron/**/*",
      "package.json"
    ]
  }
}
